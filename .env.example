# =============================================================================
# نظام إدارة الاستلام المختبري - متغيرات البيئة
# Lab Receipt & Delivery Management System - Environment Configuration
# =============================================================================

# ---- Security ----
SECRET_KEY=
# Leave empty for auto-generated key (will be generated on first run)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Database ----
# PostgreSQL (production)
DATABASE_URL=postgresql+psycopg://lab_user:lab_pass@localhost:5432/lab_txn

# SQLite (development/testing)
# DATABASE_URL=sqlite:///./lab_system.db

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---- Application ----
APP_NAME=نظام إدارة الاستلام المختبري
APP_VERSION=1.1.0
DEBUG=false
LOG_LEVEL=INFO

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# ---- Rate Limiting ----
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60

# ---- Password Policy ----
PASSWORD_MIN_LENGTH=8

# ---- Backup ----
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_ENABLED=false

# ---- Storage ----
STORAGE_ROOT=storage
